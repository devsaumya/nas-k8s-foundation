{
  "$defs": {
    "ArgoCD": {
      "additionalProperties": false,
      "properties": {
        "helmRepo": {
          "$ref": "#/$defs/HelmRepository",
          "title": "ArgoCD Helm Charts Repository"
        },
        "repo": {
          "$ref": "#/$defs/RepoProto",
          "title": "ArgoCD Git Repository"
        }
      },
      "required": [
        "repo"
      ],
      "type": "object"
    },
    "CertManagerService": {
      "additionalProperties": false,
      "properties": {
        "clusterIssuer": {
          "$ref": "#/$defs/ClusterIssuer",
          "title": "Cluster Issuer Configuration"
        },
        "status": {
          "default": "disabled",
          "description": "The desired status of the service.",
          "enum": [
            "enabled",
            "disabled"
          ],
          "title": "Service Status",
          "type": "string"
        }
      },
      "required": [
        "clusterIssuer"
      ],
      "type": "object"
    },
    "Cluster": {
      "additionalProperties": false,
      "properties": {
        "argocd": {
          "$ref": "#/$defs/ArgoCD",
          "description": "Configuration for argoCD.",
          "title": "ArgoCD"
        },
        "dnsName": {
          "description": "The fully qualified domain name for the cluster.",
          "examples": [
            "my-prod-cluster.example.com"
          ],
          "format": "hostname",
          "title": "Primary DNS Name",
          "type": "string"
        },
        "ingressClassName": {
          "default": "traefik",
          "description": "The ingress class to use for this cluster.",
          "minLength": 1,
          "title": "Ingress Class",
          "type": "string"
        },
        "name": {
          "description": "The unique name for the cluster.",
          "examples": [
            "my-prod-cluster"
          ],
          "minLength": 1,
          "title": "Cluster Name",
          "type": "string"
        },
        "privateLoadBalancerIP": {
          "description": "The static IP for the private ingress controller load balancer.",
          "format": "ipv4",
          "title": "Private Load Balancer IP",
          "type": "string"
        },
        "publicLoadBalancerIP": {
          "description": "The static IP for the public ingress controller load balancer.",
          "format": "ipv4",
          "title": "Public Load Balancer IP",
          "type": "string"
        },
        "services": {
          "$ref": "#/$defs/Services",
          "description": "Configuration for deployed services.",
          "title": "Services"
        },
        "ssoOrg": {
          "description": "The SSO organization or group allowed to access this cluster.",
          "minLength": 1,
          "title": "SSO Organization",
          "type": "string"
        },
        "ssoTeam": {
          "description": "The specific SSO team or sub-group allowed to access this cluster.",
          "minLength": 1,
          "title": "SSO Team",
          "type": "string"
        },
        "stage": {
          "default": "dev",
          "description": "The stage this cluster represents.",
          "minLength": 1,
          "title": "Deployment Stage",
          "type": "string"
        },
        "terraform": {
          "$ref": "#/$defs/Terraform",
          "description": "Configuration for terraform resources.",
          "title": "Terraform"
        },
        "type": {
          "default": "controlplane",
          "description": "The type of the cluster",
          "enum": [
            "controlplane",
            "worker"
          ],
          "title": "Cluster Type",
          "type": "string"
        }
      },
      "required": [
        "name",
        "dnsName",
        "argocd",
        "services"
      ],
      "type": "object"
    },
    "ClusterIssuer": {
      "additionalProperties": false,
      "properties": {
        "email": {
          "description": "The email address for Let's Encrypt registration.",
          "format": "email",
          "title": "ACME Email",
          "type": "string"
        },
        "name": {
          "default": "letsencrypt-staging",
          "description": "Name of the ClusterIssuer resource.",
          "examples": [
            "letsencrypt-staging"
          ],
          "minLength": 1,
          "title": "Issuer Name",
          "type": "string"
        },
        "server": {
          "default": "https://acme-staging-v02.api.letsencrypt.org/directory",
          "description": "The ACME server URL.",
          "format": "uri",
          "title": "ACME Server",
          "type": "string"
        }
      },
      "required": [
        "name",
        "email"
      ],
      "type": "object"
    },
    "DNS": {
      "additionalProperties": false,
      "properties": {
        "email": {
          "description": "Administrative email for the DNS zone.",
          "format": "email",
          "title": "Admin Email",
          "type": "string"
        },
        "name": {
          "description": "The managed DNS zone name.",
          "format": "hostname",
          "title": "DNS Zone Name",
          "type": "string"
        }
      },
      "required": [
        "name",
        "email"
      ],
      "type": "object"
    },
    "GenericService": {
      "additionalProperties": false,
      "properties": {
        "ingress": {
          "$ref": "#/$defs/IngressOverrides",
          "description": "Optional ingress settings for this service.",
          "title": "Ingress Overrides"
        },
        "status": {
          "default": "disabled",
          "description": "The desired status of the service.",
          "enum": [
            "enabled",
            "disabled"
          ],
          "title": "Service Status",
          "type": "string"
        }
      },
      "type": "object"
    },
    "HelmRepository": {
      "additionalProperties": false,
      "properties": {
        "url": {
          "description": "The Helm repository URL or OCI registry URL (without oci:// prefix)",
          "minLength": 1,
          "title": "Repository URL",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "type": "object"
    },
    "IngressOverrides": {
      "additionalProperties": false,
      "properties": {
        "annotations": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Optional ingress annotations that are merged with kubara defaults.",
          "title": "Ingress Annotations",
          "type": "object"
        }
      },
      "type": "object"
    },
    "PersistentService": {
      "additionalProperties": false,
      "properties": {
        "ingress": {
          "$ref": "#/$defs/IngressOverrides",
          "description": "Optional ingress settings for this service.",
          "title": "Ingress Overrides"
        },
        "status": {
          "default": "disabled",
          "description": "The desired status of the service.",
          "enum": [
            "enabled",
            "disabled"
          ],
          "title": "Service Status",
          "type": "string"
        },
        "storageClassName": {
          "description": "Optional storage class for services that provision persistent volumes.",
          "minLength": 1,
          "title": "Storage Class",
          "type": "string"
        }
      },
      "type": "object"
    },
    "RepoProto": {
      "additionalProperties": false,
      "properties": {
        "https": {
          "$ref": "#/$defs/RepoType",
          "title": "Https Repository"
        },
        "oci": {
          "$ref": "#/$defs/RepoType",
          "title": "Oci Repository"
        }
      },
      "type": "object"
    },
    "RepoType": {
      "additionalProperties": false,
      "properties": {
        "customer": {
          "$ref": "#/$defs/Repository",
          "title": "Customer Repository"
        },
        "managed": {
          "$ref": "#/$defs/Repository",
          "title": "Managed Repository"
        }
      },
      "required": [
        "customer",
        "managed"
      ],
      "type": "object"
    },
    "Repository": {
      "additionalProperties": false,
      "properties": {
        "targetRevision": {
          "default": "main",
          "description": "The Git branch or tag to track.",
          "minLength": 1,
          "title": "Target Revision",
          "type": "string"
        },
        "url": {
          "description": "The HTTPS URL of the Git repository.",
          "format": "uri",
          "title": "Repository URL",
          "type": "string"
        }
      },
      "required": [
        "url"
      ],
      "type": "object"
    },
    "Services": {
      "additionalProperties": false,
      "properties": {
        "argocd": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for argoCD",
          "title": "Argocd Service"
        },
        "certManager": {
          "$ref": "#/$defs/CertManagerService",
          "description": "Configuration for CertManager",
          "title": "CertManager Service"
        },
        "externalDns": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for ExternalDns",
          "title": "ExternalDns Service"
        },
        "externalSecrets": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for ExternalSecrets",
          "title": "ExternalSecrets Service"
        },
        "homerDashboard": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for HomerDashboard",
          "title": "HomerDashboard Service"
        },
        "kubePrometheusStack": {
          "$ref": "#/$defs/PersistentService",
          "description": "Configuration for KubePrometheusStack",
          "title": "KubePrometheusStack Service"
        },
        "kyverno": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for Kyverno",
          "title": "Kyverno Service"
        },
        "kyvernoPolicies": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for KyvernoPolicies",
          "title": "KyvernoPolicies Service"
        },
        "kyvernoPolicyReport": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for KyvernoPolicyReport",
          "title": "KyvernoPolicyReport Service"
        },
        "loki": {
          "$ref": "#/$defs/PersistentService",
          "description": "Configuration for Loki",
          "title": "Loki Service"
        },
        "longhorn": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for Longhorn",
          "title": "Longhorn Service"
        },
        "metalLb": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for metalLb",
          "title": "metalLb Service"
        },
        "metricsServer": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for MetricsServer",
          "title": "MetricsServer Service"
        },
        "oauth2Proxy": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for oaOauth2Proxy",
          "title": "oauth2Proxy Service"
        },
        "traefik": {
          "$ref": "#/$defs/GenericService",
          "description": "Configuration for Traefik",
          "title": "Traefik Service"
        }
      },
      "required": [
        "argocd",
        "certManager",
        "externalDns",
        "externalSecrets",
        "kubePrometheusStack",
        "traefik",
        "kyverno",
        "kyvernoPolicies",
        "kyvernoPolicyReport",
        "loki",
        "homerDashboard",
        "oauth2Proxy",
        "metricsServer",
        "metalLb",
        "longhorn"
      ],
      "type": "object"
    },
    "Terraform": {
      "additionalProperties": false,
      "properties": {
        "dns": {
          "$ref": "#/$defs/DNS",
          "description": "DNS Zone configuration",
          "title": "DNS Config"
        },
        "kubernetesType": {
          "default": "ske",
          "description": "The type of Kubernetes cluster.",
          "enum": [
            "edge",
            "ske"
          ],
          "title": "Kubernetes Type",
          "type": "string"
        },
        "kubernetesVersion": {
          "description": "The Kubernetes version for the cluster.",
          "examples": [
            "1.34"
          ],
          "pattern": "^[0-9]\\.[0-9]+(\\.[0-9]+)?$",
          "title": "Kubernetes Version",
          "type": "string"
        },
        "projectId": {
          "description": "The cloud provider project or subscription identifier. Accepts various formats depending on the provider.",
          "minLength": 1,
          "title": "Cloud Project ID",
          "type": "string"
        },
        "provider": {
          "default": "stackit",
          "description": "Infrastructure provider used for Terraform templates. Currently supported providers: stackit.",
          "minLength": 1,
          "title": "Cloud Provider",
          "type": "string"
        }
      },
      "required": [
        "projectId",
        "kubernetesVersion",
        "dns"
      ],
      "type": "object"
    }
  },
  "$id": "mem://config.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "clusters": {
      "description": "A list of cluster configurations.",
      "items": {
        "$ref": "#/$defs/Cluster"
      },
      "title": "Clusters",
      "type": "array"
    }
  },
  "type": "object"
}